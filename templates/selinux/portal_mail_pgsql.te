module portal_mail_pgsql 1.0;

require {
    type dovecot_auth_t;
    type postfix_smtpd_t;
    type postfix_cleanup_t;
    type postfix_trivial_t;
    type postfix_virtual_t;
    type postfix_local_t;
    type postgresql_port_t;
    class tcp_socket name_connect;
}

# Dovecot (passdb/userdb SQL) i Postfix (virtual_mailbox_domains/maps) łączą
# się z PostgreSQL po TCP 127.0.0.1:5432. Domyślna polityka RHEL blokuje
# name_connect z domen tych usług do postgresql_port_t, a na tym systemie NIE
# ma booleana (postfix_can_network_connect_db / dovecot_* nie istnieją — to
# dlatego setsebool w 30-postfix-dovecot.sh zgłaszał "Boolean ... is not
# defined"). Bez tej reguły Dovecot zwraca "Temporary authentication failure"
# (backend padł), a Postfix nie rozwiąże domen/skrzynek wirtualnych.
# Potwierdzone wprost z AVC: dovecot_auth_t -> postgresql_port_t name_connect.
allow dovecot_auth_t postgresql_port_t:tcp_socket name_connect;
allow postfix_smtpd_t postgresql_port_t:tcp_socket name_connect;
allow postfix_cleanup_t postgresql_port_t:tcp_socket name_connect;
allow postfix_trivial_t postgresql_port_t:tcp_socket name_connect;
allow postfix_virtual_t postgresql_port_t:tcp_socket name_connect;
allow postfix_local_t postgresql_port_t:tcp_socket name_connect;
