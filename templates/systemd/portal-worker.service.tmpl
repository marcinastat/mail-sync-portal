[Unit]
Description=Portal Poczty — worker kolejki zadań (sync/provision)
After=network.target postgresql-${PGDG_MAJOR_VERSION}.service portal-gunicorn.service
Requires=postgresql-${PGDG_MAJOR_VERSION}.service

[Service]
Type=simple
User=portal-app
Group=portal-app
WorkingDirectory=/opt/portal-app
RuntimeDirectory=portal-app
RuntimeDirectoryMode=0750

LoadCredentialEncrypted=portal-secret-key:/etc/portal/creds/portal-secret-key.cred
LoadCredentialEncrypted=portal-credential-key:/etc/portal/creds/portal-credential-key.cred

ExecStart=/opt/portal-app/venv/bin/python -m portal_app.workers.worker_main
Restart=on-failure
RestartSec=5

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/var/log/portal /var/lib/portal-app /run/portal-app /run/portal-import

[Install]
WantedBy=multi-user.target
