[Unit]
Description=Okresowe skanowanie ClamAV maildirów VM2 (pokrywa pocztę dopisaną przez imapsync, poza ścieżką SMTP miltera)
After=clamd@scan.service
Requires=clamd@scan.service

[Service]
Type=oneshot
ExecStart=/usr/bin/clamdscan --config-file=/etc/clamd.d/scan.conf --multiscan --fdpass --infected --log=/var/log/clamav/maildir-scan.log /var/mail/vhosts
User=root
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/log/clamav
ReadOnlyPaths=/var/mail/vhosts
PrivateTmp=true
