[Unit]
Description=Inkrementalne skanowanie ClamAV maildirów VM2 (poczta dopisana przez imapsync od ostatniego przebiegu)
After=clamd@scan.service
Requires=clamd@scan.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/vm2-maildir-scan.sh incremental
User=root
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/log/clamav /var/lib/vm2-scan
ReadOnlyPaths=/var/mail/vhosts
PrivateTmp=true
# Skan ma NISKI priorytet — nie może głodzić Dovecota/Postfixa. Idle IO + nice
# + sufit CPU (ok. 1,5 rdzenia) trzymają obciążenie w ryzach.
Nice=19
IOSchedulingClass=idle
CPUWeight=20
CPUQuota=150%
