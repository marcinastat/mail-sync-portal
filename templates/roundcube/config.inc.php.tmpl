<?php

$config = [];

$config['db_dsnw'] = 'pgsql://roundcube_app:${ROUNDCUBE_DB_PASSWORD}@127.0.0.1/roundcube_db';

$config['default_host'] = 'ssl://${VM2_HOSTNAME}';
$config['default_port'] = 993;
$config['smtp_server'] = 'tls://${VM2_HOSTNAME}';
$config['smtp_port'] = 587;
$config['smtp_user'] = '%u';
$config['smtp_pass'] = '%p';

// Dovecot/Postfix na VM2 mają certyfikat self-signed (ruch wyłącznie
// wewnętrzny VM1<->VM2 po prywatnej sieci). Roundcube nie ma go w truststore,
// więc weryfikacja peera by zawsze padała. Wyłączamy ją dla tych połączeń —
// VM2_HOSTNAME jest dodane do /etc/hosts na VM1 (scripts/vm1/40-roundcube.sh),
// żeby nazwa w ogóle się rozwiązywała (brak wewnętrznego DNS).
$ssl_opts = ['ssl' => ['verify_peer' => false, 'verify_peer_name' => false, 'allow_self_signed' => true]];
$config['imap_conn_options'] = $ssl_opts;
$config['smtp_conn_options'] = $ssl_opts;

$config['support_url'] = '';
$config['product_name'] = 'Portal Poczty';
$config['des_key'] = '${ROUNDCUBE_DES_KEY}';
$config['plugins'] = ['archive', 'zipdownload', 'portal_sso'];

$config['skin'] = 'elastic';
$config['language'] = 'pl_PL';

// Logowanie nieudanych prób do dedykowanego pliku — konsumowane przez
// fail2ban jail "roundcube-auth" (Faza 9).
$config['log_driver'] = 'file';
$config['log_dir'] = '/var/log/roundcube/';
$config['userlogins'] = true;

$config['session_lifetime'] = 30;
$config['ip_check'] = true;

// Branding zarządzany z panelu admina (/admin/settings/branding): product_name
// i skin_logo (jako data: URI) są zapisywane przez apply-branding.sh do
// poniższego pliku, który nadpisuje wartości domyślne ustawione wyżej. Dzięki
// temu zmiana logo/nazwy nie wymaga edycji tego pliku ani uprawnień do niego.
if (file_exists('/etc/portal/roundcube-branding.php')) {
    include('/etc/portal/roundcube-branding.php');
}
