user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log notice;
pid /run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                     '$status $body_bytes_sent "$http_referer" '
                     '"$http_user_agent" "$http_x_forwarded_for"';
    access_log /var/log/nginx/access.log main;

    sendfile on;
    keepalive_timeout 65;
    client_max_body_size 64m;  # XLS import w zaszyfrowanym archiwum

    # Rate-limiting logowania — stosowany WYŁĄCZNIE na /admin/login (portal_app,
    # osobny pojedynczy endpoint). Roundcube NIE jest tu limitowany, bo serwuje
    # wszystkie zasoby przez PHP i limit blokowałby całą aplikację — jego
    # ochrona brute-force to jail roundcube-auth w fail2ban. Patrz obszerny
    # komentarz w templates/nginx/admin.conf.tmpl. 30r/min pozwala normalnie
    # wejść na formularz (kilka żądań), a wciąż tnie zautomatyzowany brute-force.
    limit_req_zone $binary_remote_addr zone=admin_login:10m rate=30r/m;
    limit_req_status 429;

    include /etc/nginx/conf.d/*.conf;
}
