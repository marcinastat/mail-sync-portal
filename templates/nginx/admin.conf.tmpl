server {
    listen 80;
    server_name ${VM1_HOSTNAME};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name ${VM1_HOSTNAME};

    ssl_certificate     /etc/portal/tls/active/fullchain.pem;
    ssl_certificate_key /etc/portal/tls/active/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    error_page 403 /errors/403.html;
    error_page 404 /errors/404.html;
    error_page 429 /errors/429.html;
    error_page 500 502 503 504 /errors/500.html;
    location ^~ /errors/ {
        internal;
        root /var/www;
    }

    # UWAGA: Roundcube ma pojedynczy punkt wejścia PHP (index.php) i serwuje
    # przez PHP także WSZYSTKIE statyczne zasoby (static.php: CSS/JS/obrazy).
    # Otwarcie jednej strony to kilkanaście-kilkadziesiąt żądań PHP naraz.
    # Nałożenie tu nginx-owego limit_req (rate liczony w r/min) blokuje więc
    # całą aplikację przy pierwszym wejściu — obserwowane wprost jako 429/499
    # i wieczne ładowanie. Dlatego brute-force logowania do Roundcube chronimy
    # WYŁĄCZNIE jailem roundcube-auth w fail2ban (parsuje log nieudanych
    # logowań — właściwy sygnał), a nie rate-limitem nginx. Rate-limit nginx
    # zostaje tylko na /admin/login (portal_app: osobny, pojedynczy endpoint).
    root /var/www/roundcube/public_html;
    index index.php;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    # Musi być \.php(/|$), NIE \.php$ — Roundcube serwuje zasoby przez URL-e
    # w stylu PATH_INFO: /static.php/skins/elastic/styles/styles.min.css.
    # Taki URL kończy się na .css, więc \.php$ go NIE łapał i wpadał do
    # location / -> try_files -> /index.php, przez co przeglądarka dostawała
    # HTML strony logowania zamiast CSS (efekt: Roundcube bez stylów).
    # fastcgi_split_path_info rozdziela /static.php + /skins/...css, żeby
    # PHP-FPM dostał poprawny SCRIPT_FILENAME i PATH_INFO.
    location ~ \.php(/|$) {
        fastcgi_split_path_info ^(.+?\.php)(/.*)$;
        fastcgi_pass unix:/run/php-fpm/roundcube.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
    }

    location = /admin/login {
        limit_req zone=admin_login burst=10;
        proxy_pass http://unix:/run/portal-app/gunicorn.sock:;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }

    location /admin/ {
        proxy_pass http://unix:/run/portal-app/gunicorn.sock:;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }

    location /admin/static/ {
        alias /opt/portal-app/portal_app/static/;
    }
}
