Defaults:vm2-api !requiretty
# dnf uruchamiamy przez systemd-run (transient unit POZA namespace usługi —
# ProtectSystem=strict blokuje zapis do /usr,/var, więc bezpośredni sudo dnf pada
# na "Read-only file system"). Enumerujemy dokładne komendy — sudo dopuszcza tylko te.
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemd-run --quiet --pipe --wait --collect /usr/bin/dnf -y update
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemd-run --quiet --pipe --wait --collect /usr/bin/dnf -y --security update
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemd-run --quiet --pipe --wait --collect /usr/bin/dnf -q check-update
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemd-run --quiet --pipe --wait --collect /usr/bin/dnf -q check-update --security
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemd-run --quiet --pipe --wait --collect /usr/bin/dnf -q updateinfo summary --available
vm2-api ALL=(root) NOPASSWD: /usr/bin/systemctl reboot
vm2-api ALL=(root) NOPASSWD: /usr/bin/needs-restarting -r
vm2-api ALL=(root) NOPASSWD: /usr/bin/clamdscan --ping 1 -c /etc/clamd.d/scan.conf
vm2-api ALL=(root) NOPASSWD: /usr/bin/clamdscan --version -c /etc/clamd.d/scan.conf
vm2-api ALL=(root) NOPASSWD: /usr/bin/clamdscan --fdpass --multiscan -c /etc/clamd.d/scan.conf /var/mail/vhosts/*
vm2-api ALL=(clamscan) NOPASSWD: /usr/bin/freshclam
vm2-api ALL=(root) NOPASSWD: /usr/bin/doveadm quota get -u *
# Kasowanie maildira usuniętej skrzynki — helper waliduje argumenty (brak
# path-traversal), więc wieloznacznik jest bezpieczny. Skrypt leży w
# /usr/local/sbin (root:root 0755), POZA drzewem /opt/vm2-api należącym do
# vm2-api — inaczej konto usługi mogłoby go nadpisać i eskalować uprawnienia.
vm2-api ALL=(root) NOPASSWD: /usr/local/sbin/vm2-delete-maildir.sh *
