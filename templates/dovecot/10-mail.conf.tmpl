mail_location = maildir:~/Maildir
mail_uid = vmail
mail_gid = vmail
first_valid_uid = 5000
last_valid_uid = 5000
first_valid_gid = 5000
last_valid_gid = 5000

mail_plugins = $mail_plugins quota

# Ten plik NADPISUJE stockowy conf.d/10-mail.conf, który zawierał blok
# "namespace inbox { inbox = yes }". Bez jego odtworzenia Dovecot pada na
# każdym logowaniu z "namespace configuration error: inbox=yes namespace
# missing" (obserwowane — imapsync nie mógł utworzyć/wybrać folderów).
namespace inbox {
  type = private
  separator = /
  prefix =
  inbox = yes
}

# Backend quoty — bez tego `doveadm quota get` zwraca "Quota not enabled",
# a panel nie może pokazać zajętości skrzynki. Limit pochodzi z userdb
# (user_query zwraca quota_rule w dovecot-sql.conf.ext). "maildir:User quota"
# liczy zajętość z maildira. imap_quota udostępnia zajętość klientom IMAP.
plugin {
  quota = maildir:User quota
}
protocol imap {
  mail_plugins = $mail_plugins imap_quota
}
