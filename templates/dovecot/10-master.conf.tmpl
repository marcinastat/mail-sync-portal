# Nasłuch IMAP/IMAPS — ograniczenie do IP VM1 realizowane przez firewalld
# (scripts/vm2/60-firewall-rules.sh), nie przez Dovecot samo w sobie.
service imap-login {
  inet_listener imap {
    port = 143
  }
  inet_listener imaps {
    port = 993
    ssl = yes
  }
}

service lmtp {
  unix_listener /var/spool/postfix/private/dovecot-lmtp {
    group = postfix
    mode = 0600
    user = postfix
  }
}

service auth {
  unix_listener auth-userdb {
    mode = 0600
    user = vmail
  }
  # Udostępnia SASL Postfiksowi dla usługi "submission" (port 587) —
  # patrz scripts/vm2/30-postfix-dovecot.sh i templates/postfix/main.cf.tmpl.
  unix_listener /var/spool/postfix/private/auth {
    mode = 0660
    user = postfix
    group = postfix
  }
}
